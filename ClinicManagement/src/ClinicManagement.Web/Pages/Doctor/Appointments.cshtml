@page
@model DoctorAppointmentsModel
@{
    ViewData["Title"] = "Appointments";
}

<div class="page-header">
    <h2><i class="bi bi-calendar-check me-2"></i>My Appointments</h2>
</div>

@if (Model.Appointments.Any())
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Patient</th>
                        <th>Disease / Symptoms</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in Model.Appointments)
                    {
                        <tr>
                            <td>@appointment.AppointmentDate.ToString("MM/dd/yyyy")</td>
                            <td>@appointment.Timings</td>
                            <td>@appointment.PatientName</td>
                            <td>@appointment.Disease</td>
                            <td>
                                <span class="badge bg-@GetStatusBadgeClass(appointment.Status)">
                                    @appointment.Status
                                </span>
                            </td>
                            <td class="text-center action-buttons">
                                <a asp-page="/Doctor/UpdateAppointment" asp-route-id="@appointment.AppointmentID"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Update
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-calendar-x display-4 text-muted"></i>
            <p class="mt-3 text-muted">No appointments found.</p>
        </div>
    </div>
}

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "warning",
            "Confirmed" => "info",
            "Completed" => "success",
            "Cancelled" => "danger",
            _ => "secondary"
        };
    }
}
