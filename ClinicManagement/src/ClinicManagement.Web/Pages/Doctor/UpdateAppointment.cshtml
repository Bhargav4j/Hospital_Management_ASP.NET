@page
@model UpdateAppointmentModel
@{
    ViewData["Title"] = "Update Appointment";
}

<div class="page-header">
    <h2><i class="bi bi-pencil-square me-2"></i>Update Appointment</h2>
    <a asp-page="/Doctor/Appointments" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Appointments
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-file-medical me-2"></i>Appointment Details</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="AppointmentId" />

                    <div class="row mb-4">
                        <div class="col-sm-6 mb-2">
                            <span class="text-muted d-block">Patient</span>
                            <strong>@Model.Appointment?.PatientName</strong>
                        </div>
                        <div class="col-sm-6 mb-2">
                            <span class="text-muted d-block">Date</span>
                            <strong>@Model.Appointment?.AppointmentDate.ToString("MM/dd/yyyy")</strong>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-6 mb-2">
                            <span class="text-muted d-block">Time</span>
                            <strong>@Model.Appointment?.Timings</strong>
                        </div>
                        <div class="col-sm-6 mb-2">
                            <span class="text-muted d-block">Disease / Symptoms</span>
                            <strong>@Model.Appointment?.Disease</strong>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Pending">Pending</option>
                                <option value="Confirmed">Confirmed</option>
                                <option value="InProgress">In Progress</option>
                                <option value="Completed">Completed</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="BillAmount" class="form-label">Bill Amount ($)</label>
                            <input asp-for="BillAmount" class="form-control" type="number" step="0.01" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Progress" class="form-label">Progress Notes</label>
                            <textarea asp-for="Progress" class="form-control" rows="3" placeholder="Enter progress notes..."></textarea>
                        </div>

                        <div class="col-12">
                            <label asp-for="Prescription" class="form-label">Prescription</label>
                            <textarea asp-for="Prescription" class="form-control" rows="3" placeholder="Enter prescription details..."></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check-lg me-1"></i>Update Appointment
                        </button>
                        <a asp-page="/Doctor/Appointments" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
