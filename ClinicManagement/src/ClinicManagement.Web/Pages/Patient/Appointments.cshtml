@page
@model AppointmentsModel
@{
    ViewData["Title"] = "My Appointments";
}

<div class="page-header">
    <h2><i class="bi bi-calendar-check me-2"></i>My Appointments</h2>
    <a asp-page="/Patient/ViewDoctors" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Book New
    </a>
</div>

@if (Model.Appointments.Any())
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Doctor</th>
                        <th>Department</th>
                        <th>Status</th>
                        <th class="text-end">Bill Amount</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in Model.Appointments)
                    {
                        <tr>
                            <td>@appointment.AppointmentDate.ToString("MM/dd/yyyy")</td>
                            <td>@appointment.Timings</td>
                            <td>@appointment.DoctorName</td>
                            <td>@appointment.DoctorName</td>
                            <td>
                                <span class="badge bg-@GetStatusBadgeClass(appointment.Status)">
                                    @appointment.Status
                                </span>
                            </td>
                            <td class="text-end">$@appointment.BillAmount</td>
                            <td class="text-center action-buttons">
                                <a asp-page="/Patient/AppointmentDetails" asp-route-id="@appointment.AppointmentID"
                                   class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye"></i> Details
                                </a>
                                @if (appointment.Status == "Pending")
                                {
                                    <button class="btn btn-sm btn-outline-danger" onclick="confirmCancel(@appointment.AppointmentID)">
                                        <i class="bi bi-x-circle"></i> Cancel
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-calendar-x display-4 text-muted"></i>
            <p class="mt-3 text-muted">You have no appointments yet.</p>
            <a asp-page="/Patient/ViewDoctors" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Book an Appointment
            </a>
        </div>
    </div>
}

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "warning",
            "Confirmed" => "info",
            "Completed" => "success",
            "Cancelled" => "danger",
            _ => "secondary"
        };
    }
}

@section Scripts {
    <script>
        function confirmCancel(appointmentId) {
            if (confirm('Are you sure you want to cancel this appointment?')) {
                window.location.href = '/Patient/CancelAppointment?id=' + appointmentId;
            }
        }
    </script>
}
