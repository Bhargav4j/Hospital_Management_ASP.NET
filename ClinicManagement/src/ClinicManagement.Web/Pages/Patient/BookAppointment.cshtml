@page
@model BookAppointmentModel
@{
    ViewData["Title"] = "Book Appointment";
}

<div class="page-header">
    <h2><i class="bi bi-calendar-plus me-2"></i>Book Appointment with Dr. @Model.Doctor?.Name</h2>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Doctor Details</h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr><td class="fw-semibold" style="width:40%">Name</td><td>@Model.Doctor?.Name</td></tr>
                        <tr><td class="fw-semibold">Specialization</td><td>@Model.Doctor?.Specialization</td></tr>
                        <tr><td class="fw-semibold">Department</td><td>@Model.Doctor?.DepartmentName</td></tr>
                        <tr><td class="fw-semibold">Qualification</td><td>@Model.Doctor?.Qualification</td></tr>
                        <tr><td class="fw-semibold">Experience</td><td>@Model.Doctor?.Experience years</td></tr>
                        <tr><td class="fw-semibold">Charges</td><td>$@Model.Doctor?.ChargesPerVisit</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-calendar-event me-2"></i>Appointment Details</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="DoctorId" />

                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="alert alert-success py-2">
                            <i class="bi bi-check-circle me-1"></i>@Model.SuccessMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger py-2">
                            <i class="bi bi-exclamation-circle me-1"></i>@Model.ErrorMessage
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="AppointmentDate" class="form-label">Appointment Date</label>
                        <input asp-for="AppointmentDate" class="form-control" type="date" />
                        <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Timings" class="form-label">Time Slot</label>
                        <select asp-for="Timings" class="form-select">
                            <option value="">-- Select Time --</option>
                            <option value="09:00 AM">09:00 AM</option>
                            <option value="10:00 AM">10:00 AM</option>
                            <option value="11:00 AM">11:00 AM</option>
                            <option value="12:00 PM">12:00 PM</option>
                            <option value="02:00 PM">02:00 PM</option>
                            <option value="03:00 PM">03:00 PM</option>
                            <option value="04:00 PM">04:00 PM</option>
                            <option value="05:00 PM">05:00 PM</option>
                        </select>
                        <span asp-validation-for="Timings" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Disease" class="form-label">Disease / Symptoms</label>
                        <textarea asp-for="Disease" class="form-control" rows="3" placeholder="Describe your symptoms"></textarea>
                        <span asp-validation-for="Disease" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check-lg me-1"></i>Book Appointment
                        </button>
                        <a asp-page="/Patient/ViewDoctors" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
