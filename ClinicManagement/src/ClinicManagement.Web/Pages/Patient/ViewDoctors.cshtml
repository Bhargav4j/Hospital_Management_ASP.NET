@page
@model ViewDoctorsModel
@{
    ViewData["Title"] = "View Doctors";
}

<div class="page-header">
    <h2><i class="bi bi-people me-2"></i>Available Doctors</h2>
</div>

<div class="card mb-4">
    <div class="card-body search-bar">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-6 col-lg-5">
                <label class="form-label">Search Doctors</label>
                <input type="text" name="searchTerm" class="form-control"
                       placeholder="Search by name or specialization" value="@Model.SearchTerm" />
            </div>
            <div class="col-md-4 col-lg-3">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="bi bi-search me-1"></i>Search
                </button>
                <a asp-page="/Patient/ViewDoctors" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle me-1"></i>Clear
                </a>
            </div>
        </form>
    </div>
</div>

<div class="row g-4">
    @foreach (var doctor in Model.Doctors)
    {
        <div class="col-md-6 col-lg-4 d-flex">
            <div class="card doctor-card w-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">
                        <i class="bi bi-person-badge me-1 text-primary"></i>@doctor.Name
                    </h5>
                    <div class="flex-grow-1">
                        <p class="mb-1"><strong>Specialization:</strong> @doctor.Specialization</p>
                        <p class="mb-1"><strong>Department:</strong> @doctor.DepartmentName</p>
                        <p class="mb-1"><strong>Qualification:</strong> @doctor.Qualification</p>
                        <p class="mb-1"><strong>Experience:</strong> @doctor.Experience years</p>
                        <p class="mb-2"><strong>Charges per Visit:</strong> $@doctor.ChargesPerVisit</p>
                    </div>
                    <a asp-page="/Patient/BookAppointment" asp-route-doctorId="@doctor.DoctorID"
                       class="btn btn-primary mt-auto">
                        <i class="bi bi-calendar-plus me-1"></i>Book Appointment
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Doctors.Any())
{
    <div class="alert alert-info mt-3">
        <i class="bi bi-info-circle me-2"></i>No doctors found matching your criteria.
    </div>
}
