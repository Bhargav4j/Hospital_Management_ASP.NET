@page
@model AdminDepartmentsIndexModel
@{
    ViewData["Title"] = "Manage Departments";
}

<div class="page-header">
    <h2><i class="bi bi-building me-2"></i>Manage Departments</h2>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-building-add me-1"></i>Add Department
    </a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th>Department Name</th>
                    <th>Description</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model.Departments)
                {
                    <tr>
                        <td class="fw-semibold">@dept.DeptName</td>
                        <td>@dept.Description</td>
                        <td class="text-center action-buttons">
                            <a asp-page="Edit" asp-route-id="@dept.DeptNo"
                               class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
