@page
@model CreateDepartmentModel
@{
    ViewData["Title"] = "Create Department";
}

<div class="page-header">
    <h2><i class="bi bi-building-add me-2"></i>Create Department</h2>
    <a asp-page="/Admin/Departments/Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Departments
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card form-card">
            <div class="card-body p-4">
                <form method="post">
                    <div class="mb-3">
                        <label asp-for="DeptName" class="form-label">Department Name</label>
                        <input asp-for="DeptName" class="form-control" placeholder="Enter department name" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter description"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check-lg me-1"></i>Create Department
                        </button>
                        <a asp-page="/Admin/Departments/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
