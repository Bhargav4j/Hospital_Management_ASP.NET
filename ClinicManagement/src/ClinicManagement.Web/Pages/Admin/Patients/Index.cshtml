@page
@model AdminPatientsIndexModel
@{
    ViewData["Title"] = "Manage Patients";
}

<div class="page-header">
    <h2><i class="bi bi-person me-2"></i>Manage Patients</h2>
    <a asp-page="/Admin/Patients/Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Add New Patient
    </a>
</div>

@if (Model.Patients.Any())
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Gender</th>
                        <th>Birth Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var patient in Model.Patients)
                    {
                        <tr>
                            <td>@patient.Name</td>
                            <td>@patient.Email</td>
                            <td>@patient.Phone</td>
                            <td>@patient.Gender</td>
                            <td>@patient.BirthDate.ToString("MM/dd/yyyy")</td>
                            <td class="text-center action-buttons">
                                <a asp-page="/Admin/Patients/Edit" asp-route-id="@patient.PatientID"
                                   class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-page="/Admin/Patients/Delete" asp-route-id="@patient.PatientID"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-person-x display-4 text-muted"></i>
            <p class="mt-3 text-muted">No patients found.</p>
            <a asp-page="/Admin/Patients/Create" class="btn btn-primary">
                <i class="bi bi-person-plus me-1"></i>Add First Patient
            </a>
        </div>
    </div>
}
