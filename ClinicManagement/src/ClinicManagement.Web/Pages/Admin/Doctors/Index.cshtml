@page
@model AdminDoctorsIndexModel
@{
    ViewData["Title"] = "Manage Doctors";
}

<div class="page-header">
    <h2><i class="bi bi-person-badge me-2"></i>Manage Doctors</h2>
    <a asp-page="/Admin/Doctors/Create" class="btn btn-primary">
        <i class="bi bi-person-plus-fill me-1"></i>Add Doctor
    </a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Specialization</th>
                    <th>Department</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doctor in Model.Doctors)
                {
                    <tr>
                        <td>@doctor.Name</td>
                        <td>@doctor.Email</td>
                        <td>@doctor.Specialization</td>
                        <td>@doctor.DepartmentName</td>
                        <td class="text-center action-buttons">
                            <a asp-page="Edit" asp-route-id="@doctor.DoctorID"
                               class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
