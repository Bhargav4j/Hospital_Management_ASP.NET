{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AWS": {
    "Region": "us-east-1",
    "SystemsManager": {
      "Path": "/clinic-management/",
      "Enabled": true
    },
    "S3": {
      "Enabled": true,
      "BucketName": "hospwithoutdbcontcmp-files"
    },
    "Redis": {
      "Enabled": false,
      "ConnectionString": "",
      "InstanceName": "hospwithoutdbcontcmp:"
    },
    "CloudWatch": {
      "Enabled": true,
      "LogGroup": "/ecs/hospwithoutdbcontcmp"
    },
    "FeatureToggle": {
      "RequireAwsEnvironment": true
    }
  },
  "AllowedHosts": "*"
}
